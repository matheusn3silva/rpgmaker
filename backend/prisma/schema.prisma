datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Enums ─────────────────────────────────────────────────

enum SkillType {
  PASSIVA
  ATIVA_ACAO
  ATIVA_BONUS
  ATIVA_REACAO
}

enum ArchetypeType {
  ASHEN  // Corpo a corpo — Spark: (FOR + POD) / 2
  SHARD  // Velocistas    — Spark: (DES + POD) / 2
  LUMEN  // Magos         — Spark: (INT + POD) / 2
}

enum ProficiencyCategory {
  COMBATE
  SOBRENATURAL
  INVESTIGACAO
  SOCIAL
  PRATICA
  ESPECIAL
}

// ── Models ────────────────────────────────────────────────

model User {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(150)
  email    String @unique @db.VarChar(254)
  password String @db.VarChar(100)

  verified          Boolean @default(false)
  verificationToken String? @db.VarChar(255)

  resetPasswordToken   String? @db.VarChar(255)
  resetPasswordExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters Character[]
}

model RPGClass {
  id           Int    @id @default(autoincrement())
  name         String @db.VarChar(50)
  description  String
  archetype    ArchetypeType @unique
  sparkFormula String        @db.VarChar(50)

  skills     Skill[]
  characters Character[]
}

model Skill {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100) 
  type        SkillType
  description String

  sparkCost Int @default(0)
  emberCost Int @default(0)

  upgradeDescription String?
  upgradeCost        Int     @default(0)
  upgradeType        String? @db.VarChar(20)

  classId Int
  class   RPGClass @relation(fields: [classId], references: [id])
  
  @@unique([classId, name])
}

model Character {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(50)
  age          Int       @default(0)
  personality  String?   @db.VarChar(50)
  birthDate    DateTime?
  birthPlace   String?   @db.VarChar(50)
  residence    String?   @db.VarChar(50)
  occupation   String?   @db.VarChar(50)
  race         String    @db.VarChar(30)
  coins        Int       @default(0)
  history      String?
  height       Float?    @default(0)
  weight       Float?    @default(0)

  level        Int @default(1)
  experience   Int @default(0)

  // Relação de Usuário
  userId  Int
  user    User  @relation(fields: [userId], references: [id])

  // Relação de Classe
  classId Int
  class   RPGClass @relation(fields: [classId], references: [id])

  attributes    CharacterAttributes?
  status        CharacterStatus?
  proficiencies CharacterProficiency[]
  skills        CharacterSkill[]
  
  createdAt DateTime @default(now())
}

model CharacterAttributes {
  id Int @id @default(autoincrement())
  // --- Atributos Principais ---
  strength        Int      @default(10)
  dexterity       Int      @default(10)
  constitution    Int      @default(10)
  intelligence    Int      @default(10)
  education       Int      @default(10)
  presence        Int      @default(10)
  power           Int      @default(10)

  characterId Int @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model CharacterStatus {
  id Int @id @default(autoincrement())

  vitality      Int     @default(20)
  spark         Int     @default(1)
  embers        Int     @default(1)
  soul          Int     @default(0)
  initiative    Int     @default(0)
  luck          Int     @default(0)
  movement      Int     @default(1)
  energyType    String? @db.VarChar(20)

  characterId Int       @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model CharacterSkill {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  type        SkillType @default(ATIVA_ACAO)
  description String

  sparkCost Int @default(0)
  emberCost Int @default(0)

  upgradeDescription String?
  upgradeCost        Int     @default(0)
  upgradeType        String? @db.VarChar(20)

  characterId Int
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model Proficiency {
  id       Int    @id @default(autoincrement())
  name     String @unique @db.VarChar(50)
  category ProficiencyCategory

  characters CharacterProficiency[]
}

model CharacterProficiency {
  id Int @id @default(autoincrement())

  value Int @default(0)

  characterId   Int
  proficiencyId Int

  character   Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  proficiency Proficiency @relation(fields: [proficiencyId], references: [id])

  @@unique([characterId, proficiencyId])
  @@index([characterId])
  @@index([proficiencyId])
}